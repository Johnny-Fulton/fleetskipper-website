{
  "name": "seaready-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
