    "@supabase/supabase-js": "^2.86.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/nodemailer": "^7.0.9",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "framer-motion": "^12.23.11",
    "google-auth-library": "^10.5.0",
    "lucide-react": "^0.560.0",
    "next": "^15.4.8",
    "nodemailer": "^8.0.1",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.68.0",
