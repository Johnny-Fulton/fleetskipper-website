# SeaReady Environment Variables Template
# Copy to .env.local and fill in your values

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Stripe Configuration
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard)
# Starter Plan
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...

# Fleet Plan  
STRIPE_PRICE_FLEET_MONTHLY=price_...
STRIPE_PRICE_FLEET_ANNUAL=price_...

# Enterprise Plan
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# Database URL (PostgreSQL recommended)
DATABASE_URL=postgresql://user:password@localhost:5432/seaready

# Auth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Feature Flags
ENABLE_BILLING=true

# Email Configuration (optional)
RESEND_API_KEY=
FROM_EMAIL=noreply@seaready.app